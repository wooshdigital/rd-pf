<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{name}} :: {{title}}</title>
<style>
  :root {
    --fg: #33ff66;
    --fg-dim: #22aa44;
    --bg: #0a0f0a;
    --bg-alt: #121712;
    --accent: #ffbb33;
    --link: #66ccff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'SF Mono', Menlo, Monaco, Consolas, 'Courier New', monospace;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.6;
    font-size: 14px;
    min-height: 100vh;
  }
  .wrap { max-width: 820px; margin: 0 auto; padding: 40px 24px 80px; }
  .prompt { color: var(--accent); }
  .prompt::before { content: '$ '; }
  header {
    margin-bottom: 48px;
    padding: 24px;
    border: 1px solid var(--fg-dim);
    background: var(--bg-alt);
  }
  .header-top { display: flex; align-items: center; gap: 20px; margin-bottom: 16px; }
  .headshot {
    width: 80px; height: 80px; border-radius: 0;
    object-fit: cover; border: 2px solid var(--fg);
    filter: grayscale(1) contrast(1.2);
  }
  h1 { font-size: 22px; font-weight: 600; letter-spacing: 0.02em; }
  h1::before { content: '> '; color: var(--accent); }
  .subtitle { color: var(--fg-dim); font-size: 13px; margin-top: 4px; }
  .subtitle::before { content: '# '; color: var(--accent); }
  .headline {
    margin-top: 16px; padding: 12px;
    background: var(--bg); border-left: 3px solid var(--accent);
    color: var(--fg); font-style: italic;
  }
  .divider {
    color: var(--fg-dim); margin: 40px 0 16px;
    font-size: 13px; letter-spacing: 0.1em;
    overflow: hidden; white-space: nowrap;
  }
  section { margin-bottom: 40px; }
  h2 { font-size: 15px; font-weight: 600; color: var(--accent); text-transform: lowercase; }
  h2::before { content: '## '; }
  p { margin-bottom: 12px; }
  .skills { margin-top: 12px; }
  .skills span {
    display: inline-block;
    padding: 2px 8px;
    margin: 0 4px 6px 0;
    border: 1px solid var(--fg-dim);
    color: var(--fg);
    font-size: 12px;
  }
  .skills span::before { content: '['; color: var(--fg-dim); }
  .skills span::after { content: ']'; color: var(--fg-dim); }
  .project {
    margin-top: 16px; padding: 12px;
    background: var(--bg-alt);
    border-left: 2px solid var(--fg-dim);
  }
  .project h3 { font-size: 15px; font-weight: 600; color: var(--fg); margin-bottom: 4px; }
  .project h3::before { content: '→ '; color: var(--accent); }
  .project h3 a { color: var(--link); text-decoration: none; }
  .project h3 a:hover { text-decoration: underline; }
  .project-tech { color: var(--fg-dim); font-size: 12px; margin-bottom: 8px; }
  .project p { color: var(--fg); font-size: 13px; }
  .exp-item { margin-top: 12px; font-size: 13px; }
  .exp-item .role { color: var(--fg); font-weight: 600; }
  .exp-item .org { color: var(--accent); }
  .exp-item .dates { color: var(--fg-dim); font-size: 12px; }
  .contact a {
    color: var(--link); text-decoration: none; margin-right: 20px;
    display: inline-block; margin-top: 8px;
  }
  .contact a:hover { text-decoration: underline; }
  .contact a::before { content: '→ '; color: var(--accent); }
  footer { color: var(--fg-dim); text-align: center; margin-top: 60px; font-size: 12px; }
  footer::before { content: '// '; }
  .blink { animation: blink 1s step-end infinite; color: var(--accent); }
  @keyframes blink { 50% { opacity: 0; } }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="header-top">
      {{#if headshot}}<img class="headshot" src="{{headshot}}" alt="{{name}}" />{{/if}}
      <div>
        <h1>{{name}}<span class="blink">_</span></h1>
        <div class="subtitle">{{title}}</div>
      </div>
    </div>
    {{#if headline}}<div class="headline">{{headline}}</div>{{/if}}
  </header>

  {{#if aboutParagraph}}
  <div class="divider">─── about ──────────────────────────────────────────────────────────</div>
  <section>
    <h2>about</h2>
    <p>{{aboutParagraph}}</p>
    {{#if bio}}<p>{{bio}}</p>{{/if}}
  </section>
  {{/if}}

  {{#if skills.length}}
  <div class="divider">─── skills ─────────────────────────────────────────────────────────</div>
  <section>
    <h2>skills</h2>
    <div class="skills">{{#each skills}}<span>{{this}}</span>{{/each}}</div>
  </section>
  {{/if}}

  {{#if projects.length}}
  <div class="divider">─── projects ───────────────────────────────────────────────────────</div>
  <section>
    <h2>projects</h2>
    {{#each projects}}
    <div class="project">
      <h3>{{#if githubUrl}}<a href="{{githubUrl}}" target="_blank" rel="noopener">{{name}}</a>{{else}}{{name}}{{/if}}</h3>
      <div class="project-tech">{{#each tech}}{{this}}{{#unless @last}} · {{/unless}}{{/each}}</div>
      <p>{{description}}</p>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if experience.length}}
  <div class="divider">─── experience ─────────────────────────────────────────────────────</div>
  <section>
    <h2>experience</h2>
    {{#each experience}}
    <div class="exp-item">
      <div><span class="role">{{role}}</span> @ <span class="org">{{org}}</span></div>
      <div class="dates">{{start}} — {{end}}</div>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if contact}}
  <div class="divider">─── contact ────────────────────────────────────────────────────────</div>
  <section>
    <h2>contact</h2>
    <div class="contact">
      {{#if contact.email}}<a href="mailto:{{contact.email}}">{{contact.email}}</a>{{/if}}
      {{#if contact.github}}<a href="https://github.com/{{contact.github}}" target="_blank" rel="noopener">github/{{contact.github}}</a>{{/if}}
      {{#if contact.linkedin}}<a href="{{contact.linkedin}}" target="_blank" rel="noopener">linkedin</a>{{/if}}
    </div>
  </section>
  {{/if}}

  <footer>{{name}} · built with portfolio forge</footer>
</div>
</body>
</html>

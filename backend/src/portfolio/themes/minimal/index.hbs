<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{name}} — {{title}}</title>
<style>
  :root {
    --fg: #1a1a1a;
    --bg: #fafaf7;
    --muted: #666;
    --accent: #2b4a2b;
    --border: #e5e5e0;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, serif;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.7;
    font-size: 17px;
  }
  .wrap {
    max-width: 640px;
    margin: 0 auto;
    padding: 80px 24px 120px;
  }
  header { text-align: center; margin-bottom: 64px; }
  .headshot {
    width: 120px; height: 120px; border-radius: 50%;
    object-fit: cover; margin: 0 auto 24px;
    display: block;
    filter: grayscale(0.15);
  }
  h1 { font-size: 36px; font-weight: 500; letter-spacing: -0.01em; margin-bottom: 8px; }
  .subtitle { color: var(--muted); font-style: italic; font-size: 18px; }
  .headline {
    max-width: 480px; margin: 32px auto 0;
    font-size: 19px; color: var(--fg);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 24px 0;
  }
  section { margin-bottom: 56px; }
  h2 {
    font-size: 14px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  p { margin-bottom: 16px; }
  .skills { display: flex; flex-wrap: wrap; gap: 8px; }
  .skills span {
    background: transparent;
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 14px;
    color: var(--muted);
  }
  .project { margin-bottom: 28px; padding-bottom: 28px; border-bottom: 1px solid var(--border); }
  .project:last-child { border-bottom: none; }
  .project h3 { font-size: 20px; font-weight: 500; margin-bottom: 4px; }
  .project h3 a { color: var(--fg); text-decoration: none; border-bottom: 1px solid var(--accent); }
  .project-tech { color: var(--muted); font-size: 14px; font-style: italic; margin-bottom: 12px; }
  .exp-item { margin-bottom: 20px; }
  .exp-item .role { font-weight: 500; }
  .exp-item .org { color: var(--muted); }
  .exp-item .dates { color: var(--muted); font-size: 14px; font-style: italic; }
  .contact a {
    color: var(--accent); text-decoration: none;
    border-bottom: 1px solid var(--accent);
    margin-right: 24px;
  }
  footer { text-align: center; color: var(--muted); font-size: 13px; margin-top: 80px; }
</style>
</head>
<body>
<div class="wrap">
  <header>
    {{#if headshot}}<img class="headshot" src="{{headshot}}" alt="{{name}}" />{{/if}}
    <h1>{{name}}</h1>
    <div class="subtitle">{{title}}</div>
    {{#if headline}}<div class="headline">{{headline}}</div>{{/if}}
  </header>

  {{#if aboutParagraph}}
  <section>
    <h2>About</h2>
    <p>{{aboutParagraph}}</p>
    {{#if bio}}<p>{{bio}}</p>{{/if}}
  </section>
  {{/if}}

  {{#if skills.length}}
  <section>
    <h2>Skills</h2>
    <div class="skills">{{#each skills}}<span>{{this}}</span>{{/each}}</div>
  </section>
  {{/if}}

  {{#if projects.length}}
  <section>
    <h2>Projects</h2>
    {{#each projects}}
    <div class="project">
      <h3>{{#if githubUrl}}<a href="{{githubUrl}}" target="_blank" rel="noopener">{{name}}</a>{{else}}{{name}}{{/if}}</h3>
      <div class="project-tech">{{#each tech}}{{this}}{{#unless @last}} · {{/unless}}{{/each}}</div>
      <p>{{description}}</p>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if experience.length}}
  <section>
    <h2>Experience</h2>
    {{#each experience}}
    <div class="exp-item">
      <div><span class="role">{{role}}</span> · <span class="org">{{org}}</span></div>
      <div class="dates">{{start}} – {{end}}</div>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if contact}}
  <section>
    <h2>Contact</h2>
    <div class="contact">
      {{#if contact.email}}<a href="mailto:{{contact.email}}">{{contact.email}}</a>{{/if}}
      {{#if contact.github}}<a href="https://github.com/{{contact.github}}" target="_blank" rel="noopener">GitHub</a>{{/if}}
      {{#if contact.linkedin}}<a href="{{contact.linkedin}}" target="_blank" rel="noopener">LinkedIn</a>{{/if}}
    </div>
  </section>
  {{/if}}

  <footer>© {{name}}</footer>
</div>
</body>
</html>
